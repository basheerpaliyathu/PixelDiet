<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@null"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="8dp"
        android:paddingBottom="26dp">

        <!-- ───────── App bar ───────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp"
            android:paddingTop="14dp"
            android:paddingBottom="6dp">

            <FrameLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/logo_bg">
                <ImageView
                    android:layout_width="23dp"
                    android:layout_height="23dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_logo_shield"
                    android:contentDescription="@null"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="13dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PixelDiet"
                    android:textColor="@color/text_hi"
                    android:textSize="22sp"
                    android:fontFamily="@font/sora_bold"
                    android:letterSpacing="-0.022"
                    android:includeFontPadding="false"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="PURE-JVM IMAGE COMPRESSOR"
                    android:textColor="@color/muted1"
                    android:textSize="10.5sp"
                    android:fontFamily="@font/jetbrains_mono_regular"
                    android:letterSpacing="0.14"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="JVM"
                android:textColor="@color/acid"
                android:textSize="10sp"
                android:fontFamily="@font/jetbrains_mono_semibold"
                android:letterSpacing="0.12"
                android:background="@drawable/jvm_badge"
                android:paddingHorizontal="9dp"
                android:paddingVertical="5dp"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <!-- ───────── Source card ───────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/white_07"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- head -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SOURCE"
                        android:textColor="@color/muted1"
                        android:textSize="11sp"
                        android:fontFamily="@font/jetbrains_mono_semibold"
                        android:letterSpacing="0.18"/>
                    <LinearLayout
                        android:id="@+id/chipSelected"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/chip_acid"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp">
                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/dot_acid"/>
                        <TextView
                            android:id="@+id/tvSelectedCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 selected"
                            android:textColor="@color/acid"
                            android:textSize="10.5sp"
                            android:fontFamily="@font/jetbrains_mono_semibold"
                            android:letterSpacing="0.04"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- source row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/white_08"
                        app:strokeWidth="1dp">
                        <ImageView
                            android:id="@+id/ivThumb"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/photo_dusk"
                            android:scaleType="centerCrop"
                            android:contentDescription="@null"/>
                    </com.google.android.material.card.MaterialCardView>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvFname"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No image selected"
                            android:textColor="@color/text_fname"
                            android:textSize="15sp"
                            android:fontFamily="@font/sora_semibold"
                            android:letterSpacing="-0.01"
                            android:singleLine="true"
                            android:ellipsize="end"/>
                        <TextView
                            android:id="@+id/tvFsize"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Pick an image to begin"
                            android:textColor="@color/muted2"
                            android:textSize="12sp"
                            android:fontFamily="@font/jetbrains_mono_regular"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- pick buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:id="@+id/btnPickSingle"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/ghost_btn"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="17dp"
                            android:layout_height="17dp"
                            android:layout_marginEnd="9dp"
                            android:src="@drawable/ic_pick_image"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pick image"
                            android:textColor="@color/text_body"
                            android:textSize="14sp"
                            android:fontFamily="@font/sora_semibold"/>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/btnPickMultiple"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginStart="11dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/ghost_btn"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="17dp"
                            android:layout_height="17dp"
                            android:layout_marginEnd="9dp"
                            android:src="@drawable/ic_pick_multiple"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pick multiple"
                            android:textColor="@color/text_body"
                            android:textSize="14sp"
                            android:fontFamily="@font/sora_semibold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ───────── Options card ───────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/white_07"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OUTPUT FORMAT"
                    android:textColor="@color/muted1"
                    android:textSize="11sp"
                    android:fontFamily="@font/jetbrains_mono_semibold"
                    android:letterSpacing="0.18"/>

                <!-- format row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="11dp"
                    android:orientation="horizontal">
                    <include layout="@layout/part_seg" android:id="@+id/segJpeg"
                        android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"/>
                    <include layout="@layout/part_seg" android:id="@+id/segWebpLossy"
                        android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
                <!-- format row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">
                    <include layout="@layout/part_seg" android:id="@+id/segWebpLossless"
                        android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"/>
                    <include layout="@layout/part_seg" android:id="@+id/segPng"
                        android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="COMPRESSION GEAR"
                    android:textColor="@color/muted1"
                    android:textSize="11sp"
                    android:fontFamily="@font/jetbrains_mono_semibold"
                    android:letterSpacing="0.18"/>

                <!-- gear row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="11dp"
                    android:orientation="horizontal">
                    <include layout="@layout/part_seg" android:id="@+id/segSmart"
                        android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"/>
                    <include layout="@layout/part_seg" android:id="@+id/segAggressive"
                        android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"
                        android:layout_marginStart="8dp"/>
                    <include layout="@layout/part_seg" android:id="@+id/segCustom"
                        android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <!-- hard cap -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:id="@+id/toggleHardCap"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">
                        <FrameLayout
                            android:id="@+id/checkboxHardCap"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:background="@drawable/checkbox_default">
                            <ImageView
                                android:id="@+id/checkboxTick"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check"
                                android:visibility="gone"
                                android:contentDescription="@null"/>
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="11dp"
                            android:text="Hard cap"
                            android:textColor="@color/text_body"
                            android:textSize="14.5sp"
                            android:fontFamily="@font/sora_medium"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:layout_marginStart="14dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/cap_input"
                        android:paddingHorizontal="14dp">
                        <EditText
                            android:id="@+id/etHardCap"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Target size"
                            android:textColorHint="@color/muted5"
                            android:textColor="@color/text_body"
                            android:textSize="14sp"
                            android:fontFamily="@font/jetbrains_mono_regular"
                            android:inputType="number"
                            android:enabled="false"
                            android:maxLength="6"
                            android:importantForAutofill="no"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="KB"
                            android:textColor="@color/muted3"
                            android:textSize="12sp"
                            android:fontFamily="@font/jetbrains_mono_semibold"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="13dp"
                    android:text="Guarantees output ≤ N KB on any gear — a guarantee Luban 2 removed."
                    android:textColor="@color/muted3"
                    android:textSize="12.5sp"
                    android:lineSpacingMultiplier="1.2"
                    android:fontFamily="@font/sora_regular"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ───────── Compress CTA ───────── -->
        <LinearLayout
            android:id="@+id/btnCompress"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="18dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/cta_bg"
            android:clickable="true"
            android:focusable="true"
            android:elevation="6dp">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="11dp"
                android:src="@drawable/ic_play"
                android:contentDescription="@null"/>
            <TextView
                android:id="@+id/btnCompressLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Compress"
                android:textColor="@color/acid_c"
                android:textSize="16sp"
                android:fontFamily="@font/sora_bold"
                android:letterSpacing="-0.01"/>
        </LinearLayout>

        <!-- ───────── Results ───────── -->
        <LinearLayout
            android:id="@+id/resultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </LinearLayout>
</ScrollView>
