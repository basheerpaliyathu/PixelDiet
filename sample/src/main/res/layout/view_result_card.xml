<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="18dp"
    app:cardBackgroundColor="@color/card_bg"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/white_07"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- head -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="RESULT"
                android:textColor="@color/muted1"
                android:textSize="11sp"
                android:fontFamily="@font/jetbrains_mono_semibold"
                android:letterSpacing="0.18"/>
            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/time_chip"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="0 ms"
                android:textColor="@color/muted4"
                android:textSize="11sp"
                android:fontFamily="@font/jetbrains_mono_semibold"/>
        </LinearLayout>

        <!-- error state -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:textColor="#FF6B6B"
            android:textSize="13sp"
            android:fontFamily="@font/jetbrains_mono_regular"/>

        <!-- success content -->
        <LinearLayout
            android:id="@+id/resultContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- before/after photo -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="172dp"
                android:layout_marginBottom="18dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/white_08"
                app:strokeWidth="1dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:id="@+id/ivAfter"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/photo_dusk"
                        android:scaleType="centerCrop"
                        android:contentDescription="@null"/>
                    <View
                        android:layout_width="2dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/ba_line"/>
                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="center"
                        android:background="@drawable/ba_handle">
                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_ba_handle"
                            android:contentDescription="@null"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_margin="10dp"
                        android:background="@drawable/ba_tag"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:text="BEFORE"
                        android:textColor="@color/text_body"
                        android:textSize="9.5sp"
                        android:fontFamily="@font/jetbrains_mono_bold"
                        android:letterSpacing="0.18"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="10dp"
                        android:background="@drawable/ba_tag"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:text="AFTER"
                        android:textColor="@color/text_body"
                        android:textSize="9.5sp"
                        android:fontFamily="@font/jetbrains_mono_bold"
                        android:letterSpacing="0.18"/>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- savings stat -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="bottom">
                    <TextView
                        android:id="@+id/tvPct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/acid"
                        android:textSize="50sp"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:letterSpacing="-0.04"
                        android:includeFontPadding="false"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="9dp"
                        android:layout_marginBottom="6dp"
                        android:text="smaller"
                        android:textColor="@color/muted2"
                        android:textSize="14sp"
                        android:fontFamily="@font/sora_medium"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:id="@+id/tvFrom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 KB"
                        android:textColor="@color/muted3"
                        android:textSize="13sp"
                        android:fontFamily="@font/jetbrains_mono_regular"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal"
                        android:gravity="bottom">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:text="→"
                            android:textColor="@color/muted1"
                            android:textSize="13sp"
                            android:fontFamily="@font/jetbrains_mono_regular"/>
                        <TextView
                            android:id="@+id/tvTo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 KB"
                            android:textColor="@color/text_fname"
                            android:textSize="20sp"
                            android:fontFamily="@font/jetbrains_mono_bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- savings bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="9dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal"
                android:background="@drawable/bar_bg"
                android:weightSum="1000">
                <View
                    android:id="@+id/barAfter"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="430"
                    android:background="@drawable/bar_after"/>
                <View
                    android:id="@+id/barFiller"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="570"/>
            </LinearLayout>

            <!-- bar caption -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvBarOrig"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ORIGINAL 0 KB"
                    android:textColor="@color/muted3"
                    android:textSize="10sp"
                    android:fontFamily="@font/jetbrains_mono_regular"
                    android:letterSpacing="0.08"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SAVED "
                    android:textColor="@color/muted3"
                    android:textSize="10sp"
                    android:fontFamily="@font/jetbrains_mono_regular"
                    android:letterSpacing="0.08"/>
                <TextView
                    android:id="@+id/tvBarSaved"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 KB"
                    android:textColor="@color/acid"
                    android:textSize="10sp"
                    android:fontFamily="@font/jetbrains_mono_semibold"
                    android:letterSpacing="0.08"/>
            </LinearLayout>

            <!-- meta grid -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="@color/white_07"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="1dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@color/meta_bg"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="13dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FORMAT"
                                android:textColor="@color/muted3"
                                android:textSize="9.5sp"
                                android:fontFamily="@font/jetbrains_mono_regular"
                                android:letterSpacing="0.16"/>
                            <TextView
                                android:id="@+id/metaFormatValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="—"
                                android:textColor="@color/text_meta"
                                android:textSize="13sp"
                                android:fontFamily="@font/jetbrains_mono_semibold"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="1dp"
                            android:orientation="vertical"
                            android:background="@color/meta_bg"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="13dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GEAR"
                                android:textColor="@color/muted3"
                                android:textSize="9.5sp"
                                android:fontFamily="@font/jetbrains_mono_regular"
                                android:letterSpacing="0.16"/>
                            <TextView
                                android:id="@+id/metaGearValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="—"
                                android:textColor="@color/text_meta"
                                android:textSize="13sp"
                                android:fontFamily="@font/jetbrains_mono_semibold"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/meta_bg"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="13dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OUTPUT FILE"
                            android:textColor="@color/muted3"
                            android:textSize="9.5sp"
                            android:fontFamily="@font/jetbrains_mono_regular"
                            android:letterSpacing="0.16"/>
                        <TextView
                            android:id="@+id/metaFileValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="—"
                            android:textColor="@color/text_meta"
                            android:textSize="13sp"
                            android:fontFamily="@font/jetbrains_mono_semibold"
                            android:singleLine="true"
                            android:ellipsize="end"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
