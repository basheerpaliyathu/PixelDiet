<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item><color android:color="@color/screen_bg"/></item>
    <item>
        <bitmap android:src="@drawable/grid_tile" android:tileMode="repeat" android:gravity="top|left"/>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:type="radial" android:gradientRadius="520dp"
                android:centerX="0.5" android:centerY="0.02"
                android:startColor="@color/acid_06" android:endColor="@android:color/transparent"/>
        </shape>
    </item>
</layer-list>
